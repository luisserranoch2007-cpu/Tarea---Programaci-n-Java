import java.util.Scanner;
// TAREA - CALCULADORA TRIGONOMÉTRICA HIPERBÓLICA
public class CalculadoraTrigonometricaHiperbolica {
    // Funciones trigonométricas hiperbólicas
    static double senoHiperbolico(double angulo) {
        return Math.sinh(angulo);
    }
    static double cosenoHiperbolico(double angulo) {
        return Math.cosh(angulo);
    }
    static double tangenteHiperbolica(double angulo) {
        return Math.tanh(angulo);
    }
    //Imprimir menú de opciones
    static void Menu() {
        System.out.println("  Funciones Hiperbólicas:");
        System.out.println("    1. Seno hiperbólico (sinh)");
        System.out.println("    2. Coseno hiperbólico (cosh)");
        System.out.println("    3. Tangente hiperbólica (tanh)");
        System.out.println("    4. Apagar calculadora");
        System.out.println();
        System.out.print("  Seleccione la operación que desea utilizar: ");
    }
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in); //Para leer valores desde la terminal
        int operacion = -1;
        while (operacion != 4) {
            System.out.println();
            Menu();
            //Validar que se ingrese un número entero para la opción
            while (!scanner.hasNextInt()) {
                System.out.print("Debe ingresar un número entero, inténtelo nuevamente: ");
                scanner.next();
            }
            operacion = scanner.nextInt();

            //Apagar calculadora con la opción 4
            if (operacion == 4) {
                System.out.println("\nCalculadora apagada");
                break;
            }
            //Validar que se escoja una opción válida
            if (operacion < 1 || operacion > 3) {
                System.out.println("Debe seleccionar una opción del 1 al 4");
                continue;
            }

            System.out.print("Ingrese el valor del ángulo α: ");
            //Validar que el valor ingresado sea numérico (no letras ni signos)
            while (!scanner.hasNextDouble()) {
                System.out.print("Debe ingresar un número válido: ");
                scanner.next(); //Eliminar el valor inválido
            }
            double valor = scanner.nextDouble(); //Guardar el valor como double

            // Nota: sinh, cosh y tanh están definidas para todos los números reales,
            // por lo que aquí no se requiere validar el dominio (a diferencia de arcsin/arccos)

            //Declarar variables para más adelante
            double resultado = 0;
            String funcion = "";
            switch (operacion) {
                case 1:
                    resultado = senoHiperbolico(valor);
                    funcion = "sinh(" + valor + ")";
                    break;
                case 2:
                    resultado = cosenoHiperbolico(valor);
                    funcion = "cosh(" + valor + ")";
                    break;
                case 3:
                    resultado = tangenteHiperbolica(valor);
                    funcion = "tanh(" + valor + ")";
                    break;
            }
            System.out.printf("Resultado: %s = %.4f%n", //Imprimir resultado de la operación
                    funcion, resultado);
        }
        scanner.close(); //Cerrar scanner
    }
}